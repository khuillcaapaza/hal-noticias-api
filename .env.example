# ── Entorno ──────────────────────────────────────────────
# true en local (muestra errores), false en producción
APP_DEBUG=false
# '/api' en producción (HestiaCP); vacío en local
APP_BASE_PATH=/api
# true = JWT solo por HTTPS (producción). false en local (HTTP)
APP_SECURE=true

# ── Autenticación JWT ────────────────────────────────────
AUTH_ENABLED=true
# Secreto para firmar tokens (mínimo 32 caracteres aleatorios).
# DEBE ser EXACTAMENTE el mismo valor en hal-archivos-api (secreto compartido):
# este servicio EMITE el token y hal-archivos-api lo VALIDA con el mismo secreto.
JWT_SECRET=
# Duración del token en segundos (28800 = 8 horas)
JWT_TTL=28800
# SOLO desarrollo: true omite el envío SMTP y devuelve el código 2FA en la
# respuesta. NUNCA activar en producción. Por defecto false (envío real).
AUTH_2FA_DEV=false

# ── CORS (orígenes del frontend, separados por coma) ─
CORS_ORIGINS=https://hospitalantoniolorena.gob.pe,https://noticias.hospitalantoniolorena.gob.pe

# ── Base de datos MySQL ─────────────────────────
DB_HOST=localhost
DB_NAME=haladminweb_noticias_bd
DB_USER=haladminweb_noticias_bd
DB_PASS=

# ── Correo SMTP (2FA: envío del código de verificación) ──
# Cuenta dedicada: noresponder@hospitalantoniolorena.gob.pe
SMTP_HOST=mail.hospitalantoniolorena.gob.pe
# 465 = SSL/TLS (SMTP_SECURE=ssl) · 587 = STARTTLS (SMTP_SECURE=tls)
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=noresponder@hospitalantoniolorena.gob.pe
# NO poner la contraseña real aquí (archivo versionado). Va en .env
SMTP_PASS=
SMTP_FROM=noresponder@hospitalantoniolorena.gob.pe
SMTP_FROM_NAME="Sistema de Noticias - Hospital Antonio Lorena"

# ── Servicio de archivos (hal-archivos-api, subdominio archivos.*) ──
# Borrado servidor-a-servidor: la API reenvía DELETE a /posts/delete del microservicio.
FILES_API_BASE_URL=https://archivos.hospitalantoniolorena.gob.pe/files-api
# URL pública base para construir los enlaces de las imágenes de los posts.
# Debe coincidir con ARCHIVOS_POSTS_BASE_URL de hal-archivos-api.
ARCHIVOS_BASE_URL=https://archivos.hospitalantoniolorena.gob.pe/posts
