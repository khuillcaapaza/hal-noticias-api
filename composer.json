{
    "name": "hal/hal-noticias-api",
    "description": "API Slim 4 (PHP + MySQL) para noticias/posts del Hospital Antonio Lorena",
    "type": "project",
    "require": {
        "php": "^8.1",
        "jimtools/jwt-auth": "^3.0",
        "phpmailer/phpmailer": "6.9",
        "respect/validation": "^2.2",
        "slim/psr7": "^1.6",
        "slim/slim": "^4",
        "tuupola/cors-middleware": "^1.4",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    }
}
